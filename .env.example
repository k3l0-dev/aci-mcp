# aci-mcp environment configuration
# Copy this file to .env at the repo root and fill in all values.
# Never commit .env to version control.

# ── APIC connection ───────────────────────────────────────────────────────────

# APIC hostname or IP address (no scheme).
APIC_HOST=10.0.0.1

# APIC credentials
APIC_USER=admin
APIC_PASSWORD=changeme

# Set to "true" to enforce TLS certificate verification when connecting to the APIC.
# Leave as "false" for lab environments with self-signed certificates.
APIC_VERIFY_SSL=false

# ── MCP server ────────────────────────────────────────────────────────────────

# Port the MCP server listens on inside the container (Caddy proxies to this).
MCP_PORT=8000

# Comma-separated list of pre-shared bearer tokens for API key authentication.
# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Clients send: Authorization: Bearer <token>  OR  X-API-Key: <token>
# Leave empty to disable authentication (local development only).
MCP_API_KEYS=

# ── HTTPS / Caddy ─────────────────────────────────────────────────────────────

# Public hostname or internal FQDN that Caddy will serve TLS for.
# For Let's Encrypt: use a real public domain (e.g. mcp.yourdomain.com)
# For internal LAN: use an internal FQDN and run: docker compose exec caddy caddy trust
MCP_DOMAIN=mcp.example.com
