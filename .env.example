# ── APIC credentials ──────────────────────────────────────────────────────────
# Cisco DevNet Always-On sandbox: sandboxapicdc.cisco.com / admin / !v3G@!4@Y
APIC_HOST=https://your-apic.example.com
APIC_USER=admin
APIC_PASSWORD=your_password

# Set to "true" to enforce TLS certificate verification (recommended in production)
APIC_VERIFY_SSL=false

# ── MCP server ────────────────────────────────────────────────────────────────
MCP_PORT=8000

# Bearer tokens for API key authentication (comma-separated).
# Leave unset to disable auth (local development only).
# Generate tokens with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEYS=

# ── Production (docker-compose + Caddy TLS) ───────────────────────────────────
# Public hostname or internal FQDN for Caddy TLS termination.
# Let's Encrypt is used for public domains; Caddy internal CA for LAN/self-signed.
MCP_DOMAIN=mcp.yourdomain.com
